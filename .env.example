# Copy this file to .env and fill in your key.

# Required. Your OpenAI API key (used for Whisper).
OPENAI_API_KEY=sk-your-key-here

# Shared secret that protects the /api/transcribe endpoint. Required for any
# public deploy (Whisper calls cost money). Leave unset only for local dev, in
# which case the endpoint is OPEN. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ACCESS_TOKEN=

# Optional. Port for the web portal. Defaults to 3000. Hosts like Railway inject
# their own PORT, which overrides this.
PORT=3000

# Optional. Whisper model. Defaults to whisper-1.
WHISPER_MODEL=whisper-1
